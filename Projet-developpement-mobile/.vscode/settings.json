{
  "java.import.maven.enabled": true,
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.project.sourcePaths": [
    "backend/src/main/java"
  ],
  "java.project.outputPath": "backend/target/classes",
  "java.import.exclusions": [
    "fittrack-mobile/**",
    "**/node_modules/**",
    "**/.expo/**"
  ]
}
